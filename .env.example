# ================================================
# Home Stack - Infrastructure Configuration
# ================================================

# Domain Settings
DOMAIN_NAME=your-domain.com
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=changeme
ADMIN_USER=admin

# ================================================
# PostgreSQL Configuration
# ================================================
POSTGRES_VERSION=16-alpine
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=postgres
POSTGRES_PORT=15432

# n8n Database
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=changeme

# n8n-pipelines Database (general-purpose DB for n8n workflow nodes)
N8N_PIPELINES_DB_NAME=n8n-pipelines
N8N_PIPELINES_DB_USER=n8n_pipelines
N8N_PIPELINES_DB_PASSWORD=changeme

# Keycloak Database
KC_DB_NAME=keycloak
KC_DB_USER=keycloak
KC_DB_PASSWORD=changeme

# ================================================
# Keycloak Configuration
# ================================================
KC_VERSION=26.0
KC_PORT=18080
KC_SUBDOMAIN=auth
# 'start' for prod (TLS at NPM, HTTP between containers); 'start-dev' to
# bypass strict checks for local dev with self-signed loops.
KC_START_COMMAND=start
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=changeme
# External HTTPS hostname Keycloak emits in issuer / OIDC discovery URLs.
# NPM terminates TLS upstream; KC speaks plain HTTP behind it.
KC_HOSTNAME=https://auth.invariantcontinuum.io
KC_HOSTNAME_STRICT=true
KC_HTTP_ENABLED=true

# ================================================
# n8n Configuration
# ================================================
N8N_VERSION=latest
N8N_PORT=5678
N8N_SUBDOMAIN=n8n
N8N_ENCRYPTION_KEY=0/DLpWxltyEuGPePF6GEbccr1ZgLcayu

# Local Dense LLM endpoint (lazy-lamacpp on host)
N8N_DENSE_LLM_URL=http://host.docker.internal:8102/v1
N8N_DENSE_LLM_API_KEY=test

# ================================================
# PgAdmin Configuration
# ================================================
PGADMIN_VERSION=latest
PGADMIN_PORT=15050
PGADMIN_SUBDOMAIN=pgadmin

# ================================================
# Public App Routing
# ================================================
APP_SUBDOMAIN=app
DOCS_SUBDOMAIN=docs

# ================================================
# Nginx Proxy Manager Configuration
# ================================================
NPM_VERSION=latest
PUID=1000
PGID=1000

# ================================================
# Redis Configuration
# ================================================
REDIS_VERSION=7-alpine
REDIS_PORT=6379
REDIS_PASSWORD=changeme
REDIS_COMMANDER_PORT=8081
REDIS_COMMANDER_SUBDOMAIN=redis-ui

# ================================================
# Substrate Platform
# ================================================
SUBSTRATE_INGESTION_DB_NAME=substrate_ingestion
SUBSTRATE_INGESTION_DB_USER=substrate_ingestion
SUBSTRATE_INGESTION_DB_PASSWORD=changeme
SUBSTRATE_GRAPH_DB_NAME=substrate_graph
SUBSTRATE_GRAPH_DB_USER=substrate_graph
SUBSTRATE_GRAPH_DB_PASSWORD=changeme

# ================================================
# Elasticsearch Configuration
# ================================================
ES_VERSION=8.12.0
ES_PORT=9200
ES_HEAP_SIZE=512m

# ================================================
# NATS Configuration
# ================================================
NATS_VERSION=2.10-alpine
NATS_PORT=4222
NATS_HTTP_PORT=8222

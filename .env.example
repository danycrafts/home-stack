# =============================================================================
# LOCAL INFRASTRUCTURE - ENVIRONMENT CONFIGURATION
# =============================================================================

# =============================================================================
# DOMAIN CONFIGURATION
# =============================================================================
DOMAIN_NAME=invariantcontinuum.io

# =============================================================================
# ADMIN CREDENTIALS (Used across services)
# =============================================================================
ADMIN_USER=admin
ADMIN_EMAIL=admin@invariantcontinuum.io
ADMIN_PASSWORD=changeme

# =============================================================================
# POSTGRESQL - MAIN DATABASE
# =============================================================================
POSTGRES_VERSION=16-alpine
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# =============================================================================
# N8N DATABASE (PostgreSQL)
# =============================================================================
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=changeme

# =============================================================================
# KEYCLOAK DATABASE (PostgreSQL)
# =============================================================================
KC_DB_NAME=keycloak
KC_DB_USER=keycloak
KC_DB_PASSWORD=changeme

# =============================================================================
# PGADMIN - DATABASE ADMIN (Password-less mode)
# =============================================================================
PGADMIN_VERSION=latest
PGADMIN_SUBDOMAIN=pgadmin
PGADMIN_PORT=5050

# =============================================================================
# N8N - WORKFLOW AUTOMATION
# =============================================================================
N8N_VERSION=latest
N8N_SUBDOMAIN=n8n
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_ENCRYPTION_KEY=your-secure-encryption-key-here
TZ=UTC
# OAuth Configuration (Keycloak)
N8N_OAUTH_CLIENT_ID=n8n
N8N_OAUTH_CLIENT_SECRET=n8n-client-secret

# =============================================================================
# KEYCLOAK - IDENTITY & ACCESS MANAGEMENT
# =============================================================================
KC_VERSION=latest
KC_SUBDOMAIN=auth
KC_PORT=8080

# =============================================================================
# NGINX PROXY MANAGER - REVERSE PROXY
# =============================================================================
NPM_VERSION=latest
NPM_ADMIN_SUBDOMAIN=npm
NPM_HTTP_PORT=80
NPM_HTTPS_PORT=443
NPM_ADMIN_PORT=81

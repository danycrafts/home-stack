# ================================================
# Home Stack - Infrastructure Configuration
# ================================================

# Domain Settings
DOMAIN_NAME=your-domain.com
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=changeme
ADMIN_USER=admin

# ================================================
# PostgreSQL Configuration
# ================================================
POSTGRES_VERSION=16-alpine
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=postgres
POSTGRES_PORT=15432

# n8n Database
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=changeme

# Keycloak Database
KC_DB_NAME=keycloak
KC_DB_USER=keycloak
KC_DB_PASSWORD=changeme

# ================================================
# Keycloak Configuration
# ================================================
KC_VERSION=latest
KC_PORT=18080
KC_SUBDOMAIN=auth

# ================================================
# n8n Configuration
# ================================================
N8N_VERSION=latest
N8N_PORT=5678
N8N_SUBDOMAIN=n8n

# ================================================
# PgAdmin Configuration
# ================================================
PGADMIN_VERSION=latest
PGADMIN_PORT=15050
PGADMIN_SUBDOMAIN=pgadmin

# ================================================
# Public App Routing
# ================================================
APP_SUBDOMAIN=app
DOCS_SUBDOMAIN=docs

# ================================================
# Nginx Proxy Manager Configuration
# ================================================
NPM_VERSION=latest
PUID=1000
PGID=1000

# ================================================
# Redis Configuration
# ================================================
REDIS_VERSION=7-alpine
REDIS_PORT=6379
REDIS_PASSWORD=changeme
REDIS_COMMANDER_PORT=8081
REDIS_COMMANDER_SUBDOMAIN=redis-ui

# ================================================
# Substrate Platform
# ================================================
SUBSTRATE_INGESTION_DB_NAME=substrate_ingestion
SUBSTRATE_INGESTION_DB_USER=substrate_ingestion
SUBSTRATE_INGESTION_DB_PASSWORD=changeme
SUBSTRATE_GRAPH_DB_NAME=substrate_graph
SUBSTRATE_GRAPH_DB_USER=substrate_graph
SUBSTRATE_GRAPH_DB_PASSWORD=changeme

# ================================================
# Elasticsearch Configuration
# ================================================
ES_VERSION=8.12.0
ES_PORT=9200
ES_HEAP_SIZE=512m

# ================================================
# NATS Configuration
# ================================================
NATS_VERSION=2.10-alpine
NATS_PORT=4222
NATS_HTTP_PORT=8222

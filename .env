# =============================================================================
# LOCAL INFRASTRUCTURE - ENVIRONMENT CONFIGURATION
# =============================================================================

# =============================================================================
# DOMAIN CONFIGURATION
# =============================================================================
DOMAIN_NAME=invariantcontinuum.io

# =============================================================================
# ADMIN CREDENTIALS (Used across services)
# =============================================================================
ADMIN_USER=admin
ADMIN_EMAIL=admin@invariantcontinuum.io
ADMIN_PASSWORD=changeme

# =============================================================================
# CORE - POSTGRESQL
# =============================================================================
POSTGRES_VERSION=16-alpine
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# =============================================================================
# CORE - N8N DATABASE
# =============================================================================
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=changeme

# =============================================================================
# CORE - KEYCLOAK DATABASE
# =============================================================================
KC_DB_NAME=keycloak
KC_DB_USER=keycloak
KC_DB_PASSWORD=changeme

# =============================================================================
# CORE - KEYCLOAK
# =============================================================================
KC_VERSION=latest
KC_SUBDOMAIN=auth
KC_PORT=8080

# =============================================================================
# CORE - PGADMIN
# =============================================================================
PGADMIN_VERSION=latest
PGADMIN_SUBDOMAIN=pgadmin
PGADMIN_PORT=5050

# =============================================================================
# CORE - NGINX PROXY MANAGER
# =============================================================================
NPM_VERSION=latest
NPM_ADMIN_SUBDOMAIN=npm
NPM_HTTP_PORT=80
NPM_HTTPS_PORT=443
NPM_ADMIN_PORT=81

# =============================================================================
# APPS - N8N
# =============================================================================
N8N_VERSION=latest
N8N_SUBDOMAIN=n8n
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_ENCRYPTION_KEY=your-secure-encryption-key-here
TZ=UTC
# OAuth Configuration (Keycloak)
N8N_OAUTH_CLIENT_ID=n8n
N8N_OAUTH_CLIENT_SECRET=n8n-client-secret
# Redis for Queue Mode
N8N_REDIS_HOST=redis
N8N_REDIS_PORT=6379

# =============================================================================
# DATA - REDIS
# =============================================================================
REDIS_VERSION=7-alpine
REDIS_PORT=6379
REDIS_PASSWORD=changeme
REDIS_SUBDOMAIN=redis

# =============================================================================
# DATA - MINIO (S3-compatible object storage)
# =============================================================================
MINIO_VERSION=latest
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_SUBDOMAIN=minio
MINIO_CONSOLE_SUBDOMAIN=minio-console
MINIO_DB_NAME=minio
MINIO_DB_USER=minio
MINIO_DB_PASSWORD=changeme

# =============================================================================
# SUBSTRATE PLATFORM
# =============================================================================
SUBSTRATE_INGESTION_DB_NAME=substrate_ingestion
SUBSTRATE_INGESTION_DB_USER=substrate_ingestion
SUBSTRATE_INGESTION_DB_PASSWORD=changeme
SUBSTRATE_GRAPH_DB_NAME=substrate_graph
SUBSTRATE_GRAPH_DB_USER=substrate_graph
SUBSTRATE_GRAPH_DB_PASSWORD=changeme

# =============================================================================
# DATA - QDRANT (Vector Database)
# =============================================================================
QDRANT_VERSION=latest
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_SUBDOMAIN=qdrant

# =============================================================================
# DATA - NEO4J (Graph Database)
# =============================================================================
NEO4J_VERSION=latest
NEO4J_AUTH=neo4j/changeme
NEO4J_HEAP_SIZE=1G
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_SUBDOMAIN=neo4j

# =============================================================================
# DATA - ELASTICSEARCH
# =============================================================================
ELASTIC_VERSION=8.11.0
ELASTIC_HEAP_SIZE=512m
ELASTIC_HTTP_PORT=9200
ELASTIC_TRANSPORT_PORT=9300
ELASTIC_SUBDOMAIN=elasticsearch

# =============================================================================
# DATA - NATS (3-Node Cluster)
# =============================================================================
NATS_VERSION=2.10-alpine
NATS_SUBDOMAIN=nats
# Node 1
NATS_CLIENT_PORT_1=4222
NATS_HTTP_PORT_1=8222
# Node 2
NATS_CLIENT_PORT_2=4223
NATS_HTTP_PORT_2=8223
# Node 3
NATS_CLIENT_PORT_3=4224
NATS_HTTP_PORT_3=8224

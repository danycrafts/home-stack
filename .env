# =============================================================================
# LOCAL INFRASTRUCTURE - ENVIRONMENT CONFIGURATION
# =============================================================================

# =============================================================================
# DOMAIN CONFIGURATION
# =============================================================================
DOMAIN_NAME=invariantcontinuum.io

# =============================================================================
# POSTGRESQL - DATABASE
# =============================================================================
POSTGRES_VERSION=16-alpine
POSTGRES_USER=postgres
POSTGRES_PASSWORD=testpass123
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# n8n Database (auto-created on init)
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=testpass123

# =============================================================================
# PGADMIN - DATABASE ADMIN
# =============================================================================
PGADMIN_VERSION=latest
PGADMIN_EMAIL=admin@invariantcontinuum.io
PGADMIN_PASSWORD=testpass123
PGADMIN_PORT=5050
PGADMIN_SUBDOMAIN=pgadmin

# =============================================================================
# N8N - WORKFLOW AUTOMATION
# =============================================================================
N8N_VERSION=latest
N8N_PORT=5678
N8N_SUBDOMAIN=n8n
N8N_PROTOCOL=http
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=testpass123
TZ=UTC

# =============================================================================
# NGINX PROXY MANAGER - REVERSE PROXY
# =============================================================================
NPM_VERSION=latest
NPM_HTTP_PORT=80
NPM_HTTPS_PORT=443
NPM_ADMIN_PORT=81
NPM_ADMIN_SUBDOMAIN=npm
NPM_ADMIN_EMAIL=admin@invariantcontinuum.io
NPM_ADMIN_PASSWORD=testpass123
